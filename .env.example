# d1ff — Environment Variable Reference
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed and safe to share.

# =============================================================================
# REQUIRED — app will not start without these
# =============================================================================

# GitHub App credentials (from https://github.com/settings/apps/<your-app>)
GITHUB_APP_ID=123456
# PEM private key — in Docker env files (--env-file .env) newlines must be \n literals.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub OAuth (for web UI login — from GitHub App OAuth settings)
GITHUB_CLIENT_ID=Iv1.abc123
GITHUB_CLIENT_SECRET=your-oauth-client-secret

# Encryption key for API keys stored at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-fernet-key-base64-encoded=

# Session secret for web UI cookies (use a long random string)
SESSION_SECRET_KEY=your-session-secret-here

# =============================================================================
# OPTIONAL — have sensible defaults
# =============================================================================

# LLM provider configuration (can also be set per-installation via the web UI)
# Supported providers: openai, anthropic, gemini, deepseek
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.openai.com/v1  # Override for Azure OpenAI or custom endpoints

# LiteLLM model names (used internally by the review engine)
LITELLM_DEFAULT_MODEL=gpt-4o-mini     # Default model for reviews
LITELLM_FALLBACK_MODEL=               # Optional fallback model (empty = no fallback)

# Concurrency and rate limiting
MAX_CONCURRENT_REVIEWS=5
RATE_LIMIT_RPM=60

# Storage (SQLite by default; replace with PostgreSQL URL for production)
DATABASE_URL=sqlite+aiosqlite:////data/d1ff.db

# Observability
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR

# Server
HOST=0.0.0.0
PORT=8000
